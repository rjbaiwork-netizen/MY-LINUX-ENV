{
    "name": "My Linux Environment",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu", // উবুন্টু ভিত্তিক অফিশিয়াল ইমেজ

    // কন্টেইনার তৈরি হওয়ার পর কোন কোন ফিচার বা টুলস ইনস্টল হবে
    "features": {
        "ghcr.io/devcontainers/features/common-utils:1": {
            "installZsh": true,
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/devcontainers/features/git:1": "latest",
        "ghcr.io/devcontainers/features/python:1": "latest"
    },

    // VS Code-এর ভেতরকার সেটিংস এবং এক্সটেনশন কনফিগারেশন
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "editor.formatOnSave": true
            },
            "extensions": [
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "yzhang.markdown-all-in-one"
            ]
        }
    },

    // কন্টেইনারটি তৈরি হওয়ার পর স্বয়ংক্রিয়ভাবে কোনো কমান্ড রান করতে চাইলে
    "postCreateCommand": "chmod +x scripts/setup.sh && ./scripts/setup.sh",

    // লিনাক্স এনভায়রনমেন্টে কোন ইউজারে লগইন হবে
    "remoteUser": "vscode"
}
